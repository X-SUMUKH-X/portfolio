# ------------------------------------------------------------------------------
# ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Copy this file to .env or .env.local and populate with your own values.
# ------------------------------------------------------------------------------

# Frontend Environment Variables (Vite prefixed, safe for client-side inclusion)
# WARNING: Do NOT put secrets or private keys here. Prefix with VITE_ to expose to the browser.
VITE_FORMSUBMIT_EMAIL=

# Example of a public configuration (not a secret)
VITE_ANALYTICS_ID=
